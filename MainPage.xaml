<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lopputoo.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30"
            Spacing="12"
            VerticalOptions="Center">

            <Label
                Text="Garden Defender Prototype"
                HorizontalOptions="Center" />

            <Button
                Text="Register"
                HorizontalOptions="Fill" />

            <Button
                Text="Login"
                HorizontalOptions="Fill" />

            <Button
                Text="Settings"
                HorizontalOptions="Fill" />

            <Button
                Text="Play"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
