<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lopputoo.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F4FAF0, Dark=#142116}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="HomeButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#3B8A58, Dark=#78B483}" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light=White, Dark=#102016}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="AccentHomeButtonStyle" TargetType="Button" BasedOn="{StaticResource HomeButtonStyle}">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F2C94C, Dark=#D6B84A}" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#24422B, Dark=#102016}" />
            </Style>

            <Style x:Key="TopBarButtonStyle" TargetType="Button" BasedOn="{StaticResource HomeButtonStyle}">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="HeightRequest" Value="40" />
                <Setter Property="Padding" Value="12,0" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="20,16,20,28" RowDefinitions="Auto,*,Auto,*">
        <Grid
            Grid.Row="0"
            ColumnDefinitions="Auto,Auto,*"
            ColumnSpacing="8"
            VerticalOptions="Start">

            <Button
                Grid.Column="0"
                Text="Register"
                Clicked="OnRegisterClicked"
                Style="{StaticResource TopBarButtonStyle}" />

            <Button
                Grid.Column="1"
                Text="Login"
                Clicked="OnLoginClicked"
                Style="{StaticResource TopBarButtonStyle}" />

            <Label
                x:Name="CurrentUserLabel"
                Grid.Column="2"
                FontSize="14"
                TextColor="{AppThemeBinding Light=#24422B, Dark=#D9F2D2}"
                VerticalTextAlignment="Center"
                HorizontalTextAlignment="End" />
        </Grid>

        <VerticalStackLayout
            Grid.Row="2"
            Spacing="18"
            HorizontalOptions="Fill">

            <VerticalStackLayout Spacing="4">
                <Label
                    Text="Garden Defender"
                    FontSize="34"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light=#24422B, Dark=#D9F2D2}"
                    HorizontalTextAlignment="Center" />

                <Label
                    Text="Prototype"
                    FontSize="18"
                    TextColor="{AppThemeBinding Light=#5E7D61, Dark=#A9CFA6}"
                    HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <BoxView
                Color="{AppThemeBinding Light=#F2C94C, Dark=#D6B84A}"
                HeightRequest="2"
                WidthRequest="90"
                HorizontalOptions="Center" />

            <Button
                Text="Settings"
                Clicked="OnSettingsClicked"
                Style="{StaticResource AccentHomeButtonStyle}" />

            <Button
                Text="Play"
                Style="{StaticResource HomeButtonStyle}" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>
