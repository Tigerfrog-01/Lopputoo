<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lopputoo.Views.GamePage"
             Title="Play"
             BackgroundColor="{AppThemeBinding Light=#F4FAF0, Dark=#142116}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="LaneLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#24422B, Dark=#D9F2D2}" />
                <Setter Property="VerticalTextAlignment" Value="Center" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
            </Style>

            <Style x:Key="GameButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#3B8A58, Dark=#78B483}" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light=White, Dark=#102016}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="20" RowDefinitions="Auto,*,Auto" RowSpacing="16">
        <VerticalStackLayout
            Grid.Row="0"
            Spacing="8">
            <Label
                Text="Game"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=#24422B, Dark=#D9F2D2}"
                HorizontalTextAlignment="Center" />

            <HorizontalStackLayout
                Spacing="10"
                HorizontalOptions="Center"
                VerticalOptions="Center">
                <Image
                    Source="cactus.png"
                    WidthRequest="64"
                    HeightRequest="64"
                    Aspect="AspectFit">
                    <Image.GestureRecognizers>
                        <DragGestureRecognizer
                            CanDrag="True"
                            DragStarting="OnCactusDragStarting" />
                    </Image.GestureRecognizers>
                </Image>

                <Label
                    Text="Drag cactus"
                    FontSize="16"
                    TextColor="{AppThemeBinding Light=#24422B, Dark=#D9F2D2}"
                    VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <Grid
            Grid.Row="1"
            RowDefinitions="*,*,*"
            RowSpacing="12">

            <Border
                Grid.Row="0"
                BackgroundColor="{AppThemeBinding Light=#DDEECF, Dark=#203524}"
                Stroke="{AppThemeBinding Light=#88A978, Dark=#78B483}"
                StrokeThickness="2">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*" Padding="12">
                    <Border
                        x:Name="PlantSquare1"
                        Grid.Column="0"
                        WidthRequest="86"
                        HeightRequest="86"
                        BackgroundColor="{AppThemeBinding Light=#EEF7E7, Dark=#142116}"
                        Stroke="{AppThemeBinding Light=#3B8A58, Dark=#78B483}"
                        StrokeThickness="2"
                        VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <DropGestureRecognizer
                                AllowDrop="True"
                                Drop="OnPlantSquareDrop" />
                        </Border.GestureRecognizers>
                        <Grid
                            Padding="6,4"
                            RowDefinitions="8,*">
                            <Label
                                x:Name="PlantSquareLabel1"
                                Grid.RowSpan="2"
                                Text="Drop"
                                FontSize="14"
                                TextColor="{AppThemeBinding Light=#24422B, Dark=#D9F2D2}"
                                VerticalTextAlignment="Center"
                                HorizontalTextAlignment="Center" />
                            <ProgressBar
                                x:Name="CactusHealthBar1"
                                Grid.Row="0"
                                Progress="1"
                                ProgressColor="#3B8A58"
                                BackgroundColor="#8FBF8F"
                                IsVisible="False" />
                            <Image
                                x:Name="PlacedCactusImage1"
                                Grid.Row="1"
                                Source="cactus.png"
                                WidthRequest="60"
                                HeightRequest="60"
                                Aspect="AspectFit"
                                IsVisible="False" />
                        </Grid>
                    </Border>

                    <AbsoluteLayout
                        x:Name="Lane1ShotArea"
                        Grid.Column="1">
                        <Label
                            Text="Lane 1"
                            Style="{StaticResource LaneLabelStyle}"
                            AbsoluteLayout.LayoutBounds="0.5,0.5,-1,-1"
                            AbsoluteLayout.LayoutFlags="PositionProportional" />
                        <Grid
                            x:Name="FishFingerEnemy"
                            RowDefinitions="8,*"
                            WidthRequest="90"
                            HeightRequest="66"
                            AbsoluteLayout.LayoutBounds="1,0.5,90,66"
                            AbsoluteLayout.LayoutFlags="PositionProportional">
                            <ProgressBar
                                x:Name="FishFingerHealthBar"
                                Grid.Row="0"
                                Progress="1"
                                ProgressColor="#C0392B"
                                BackgroundColor="#DDA19B" />
                            <Image
                                x:Name="FishFingerImage"
                                Grid.Row="1"
                                Source="fishfinger.png"
                                WidthRequest="80"
                                HeightRequest="52"
                                Aspect="AspectFit" />
                        </Grid>
                    </AbsoluteLayout>
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light=#DDEECF, Dark=#203524}"
                Stroke="{AppThemeBinding Light=#88A978, Dark=#78B483}"
                StrokeThickness="2">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*" Padding="12">
                    <Border
                        x:Name="PlantSquare2"
                        Grid.Column="0"
                        WidthRequest="86"
                        HeightRequest="86"
                        BackgroundColor="{AppThemeBinding Light=#EEF7E7, Dark=#142116}"
                        Stroke="{AppThemeBinding Light=#3B8A58, Dark=#78B483}"
                        StrokeThickness="2"
                        VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <DropGestureRecognizer
                                AllowDrop="True"
                                Drop="OnPlantSquareDrop" />
                        </Border.GestureRecognizers>
                        <Grid
                            Padding="6,4"
                            RowDefinitions="8,*">
                            <Label
                                x:Name="PlantSquareLabel2"
                                Grid.RowSpan="2"
                                Text="Drop"
                                FontSize="14"
                                TextColor="{AppThemeBinding Light=#24422B, Dark=#D9F2D2}"
                                VerticalTextAlignment="Center"
                                HorizontalTextAlignment="Center" />
                            <ProgressBar
                                x:Name="CactusHealthBar2"
                                Grid.Row="0"
                                Progress="1"
                                ProgressColor="#3B8A58"
                                BackgroundColor="#8FBF8F"
                                IsVisible="False" />
                            <Image
                                x:Name="PlacedCactusImage2"
                                Grid.Row="1"
                                Source="cactus.png"
                                WidthRequest="60"
                                HeightRequest="60"
                                Aspect="AspectFit"
                                IsVisible="False" />
                        </Grid>
                    </Border>

                    <AbsoluteLayout
                        x:Name="Lane2ShotArea"
                        Grid.Column="1">
                        <Label
                            Text="Lane 2"
                            Style="{StaticResource LaneLabelStyle}"
                            AbsoluteLayout.LayoutBounds="0.5,0.5,-1,-1"
                            AbsoluteLayout.LayoutFlags="PositionProportional" />
                    </AbsoluteLayout>
                </Grid>
            </Border>

            <Border
                Grid.Row="2"
                BackgroundColor="{AppThemeBinding Light=#DDEECF, Dark=#203524}"
                Stroke="{AppThemeBinding Light=#88A978, Dark=#78B483}"
                StrokeThickness="2">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*" Padding="12">
                    <Border
                        x:Name="PlantSquare3"
                        Grid.Column="0"
                        WidthRequest="86"
                        HeightRequest="86"
                        BackgroundColor="{AppThemeBinding Light=#EEF7E7, Dark=#142116}"
                        Stroke="{AppThemeBinding Light=#3B8A58, Dark=#78B483}"
                        StrokeThickness="2"
                        VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <DropGestureRecognizer
                                AllowDrop="True"
                                Drop="OnPlantSquareDrop" />
                        </Border.GestureRecognizers>
                        <Grid
                            Padding="6,4"
                            RowDefinitions="8,*">
                            <Label
                                x:Name="PlantSquareLabel3"
                                Grid.RowSpan="2"
                                Text="Drop"
                                FontSize="14"
                                TextColor="{AppThemeBinding Light=#24422B, Dark=#D9F2D2}"
                                VerticalTextAlignment="Center"
                                HorizontalTextAlignment="Center" />
                            <ProgressBar
                                x:Name="CactusHealthBar3"
                                Grid.Row="0"
                                Progress="1"
                                ProgressColor="#3B8A58"
                                BackgroundColor="#8FBF8F"
                                IsVisible="False" />
                            <Image
                                x:Name="PlacedCactusImage3"
                                Grid.Row="1"
                                Source="cactus.png"
                                WidthRequest="60"
                                HeightRequest="60"
                                Aspect="AspectFit"
                                IsVisible="False" />
                        </Grid>
                    </Border>

                    <AbsoluteLayout
                        x:Name="Lane3ShotArea"
                        Grid.Column="1">
                        <Label
                            Text="Lane 3"
                            Style="{StaticResource LaneLabelStyle}"
                            AbsoluteLayout.LayoutBounds="0.5,0.5,-1,-1"
                            AbsoluteLayout.LayoutFlags="PositionProportional" />
                    </AbsoluteLayout>
                </Grid>
            </Border>
        </Grid>

        <Button
            Grid.Row="2"
            Text="Back"
            Clicked="OnBackClicked"
            Style="{StaticResource GameButtonStyle}" />
    </Grid>
</ContentPage>
